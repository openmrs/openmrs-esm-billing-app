{
  "name": "@epcare/esm-billing-app",
  "version": "1.2.0",
  "description": "O3 frontend module for handling billing concerns in healthcare settings",
  "browser": "dist/epcare-esm-billing-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "homepage": "https://github.com/openmrs/openmrs-esm-billing-app#readme",
  "scripts": {
    "start": "openmrs develop",
    "analyze": "rspack --mode=production --env.analyze=true",
    "build": "rspack --mode production",
    "coverage": "cross-env TZ=UTC vitest run --coverage --passWithNoTests",
    "debug": "npm run serve",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.workspace.tsx' 'src/**/*.modal.tsx' 'src/index.ts' --config ./tools/i18next-parser.config.js",
    "lint": "eslint src --ext ts,tsx --max-warnings=0",
    "postinstall": "husky install",
    "prettier": "prettier --config prettier.config.js --write \"src/**/*.{ts,tsx,css,scss}\" \"e2e/**/*.ts\"",
    "serve": "rspack serve --mode=development",
    "test-e2e": "playwright test",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch",
    "verify": "turbo lint && turbo typescript && turbo test --color --concurrency=5"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-billing-app#readme"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-billing-app/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.109.0",
    "@hookform/resolvers": "^3.3.4",
    "classnames": "^2.5.1",
    "file-saver": "^2.0.5",
    "fuzzy": "^0.1.3",
    "lodash-es": "^4.17.21",
    "react-hook-form": "^7.49.3",
    "react-to-print": "^3.1.1",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "10.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "rxjs": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "^10.0.1-pre.4866",
    "@playwright/test": "^1.49.0",
    "@swc/cli": "^0.3.2",
    "@swc/core": "^1.3.106",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.3.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.18.4",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "d3-selection": "^3.0.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.1",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-vitest": "^0.4.0",
    "file-saver": "^2.0.5",
    "husky": "^9.0.6",
    "i18next": "^25.0.0",
    "i18next-parser": "^8.12.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.2.10",
    "lodash": "^4.17.21",
    "openmrs": "^10.0.1-pre.4866",
    "pinst": "^3.0.0",
    "prettier": "^3.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.21.3",
    "rxjs": "^6.6.7",
    "sass": "^1.70.0",
    "swr": "^2.2.4",
    "turbo": "^2.5.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix --max-warnings 0",
    "*.{css,scss,ts,tsx}": "prettier --write --list-different"
  },
  "packageManager": "yarn@4.9.1"
}
